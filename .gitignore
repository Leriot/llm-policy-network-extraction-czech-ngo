# Thesis data deposit
# The full retained corpus, interim pipeline outputs, processed JSONL/DB
# datasets, validation history, and network matrices are deposited on Zenodo
# rather than committed to GitHub. Keep local copies in these paths after
# downloading/extracting the Zenodo archive.
data/raw/**
data/interim/**
data/processed/full_dataset/**
data/processed/final_validation/**
data/processed/network/**
data/processed/validation_history/**
data/processed/provenance/**

